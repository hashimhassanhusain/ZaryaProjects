# ============================================
# ZARYA — Required Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive — Shared Drive parent folder ID
GOOGLE_DRIVE_PARENT_FOLDER_ID=your_shared_drive_folder_id_here

# Google Drive — Code backup folder ID (optional)
GOOGLE_DRIVE_CODE_BACKUP_FOLDER_ID=your_backup_folder_id_here

# Google Drive — Service Account credentials as JSON string
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
