{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "project-manager", "engineer", "safety-officer", "technical-office"] },
        "photoURL": { "type": "string", "format": "uri" },
        "accessiblePages": { "type": "array", "items": { "type": "string" } },
        "accessibleProjects": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "BOQItem": {
      "title": "BOQ Item",
      "description": "A single item in the Bill of Quantities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "rate": { "type": "number" },
        "amount": { "type": "number" },
        "division": { "type": "string" },
        "workPackage": { "type": "string" },
        "location": { "type": "string" },
        "completion": { "type": "number" }
      },
      "required": ["description", "unit", "quantity", "rate", "amount", "division", "workPackage", "location", "completion"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "A purchase order for materials or labor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "poId": { "type": "string" },
        "supplier": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Draft", "Pending", "Approved", "Closed"] },
        "amount": { "type": "number" },
        "contractId": { "type": "string" },
        "workPackageId": { "type": "string" },
        "lineItems": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["poId", "supplier", "date", "status", "amount", "workPackageId"]
    },
    "DailyReport": {
      "title": "Progress Report",
      "description": "A site progress report (daily, weekly, or monthly).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "discipline": { "type": "string", "enum": ["Civil", "Mechanical", "Electrical", "TO", "HSE"] },
        "date": { "type": "string", "format": "date" },
        "weather": { "type": "object" },
        "activities": { "type": "array", "items": { "type": "object" } },
        "generalWorks": { "type": "string" },
        "deliverables": { "type": "string" },
        "incidents": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "submittedBy": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["type", "discipline", "date", "submittedBy", "projectId"]
    },
    "SiteIssue": {
      "title": "Site Issue",
      "description": "A technical issue or task assigned to an engineer.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedToId": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "status": { "type": "string", "enum": ["Open", "Resolved"] },
        "reportId": { "type": "string" }
      },
      "required": ["title", "description", "assignedToId", "severity", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "A construction or engineering project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "manager": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "driveFolderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Todo", "In Progress", "Completed", "Blocked"] },
        "assigneeId": { "type": "string" },
        "workspaceId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] }
      },
      "required": ["title", "status", "workspaceId"]
    },
    "Workspace": {
      "title": "Workspace",
      "description": "A collaborative workspace for tasks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Project meeting records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "attendeeIds": { "type": "array", "items": { "type": "string" } },
        "minutes": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["topic", "date"]
    },
    "ChangeManagementPlan": {
      "title": "Change Management Plan",
      "description": "Project change management plan and CCB members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "approach": { "type": "string" },
        "definitions": { "type": "string" },
        "budgetThreshold": { "type": "number" },
        "scheduleThreshold": { "type": "number" },
        "ccbMembers": { "type": "array", "items": { "type": "object" } },
        "version": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["projectId", "approach", "definitions", "budgetThreshold", "scheduleThreshold", "version"]
    },
    "ChangeManagementVersion": {
      "title": "Change Management Version",
      "description": "Historical versions of the Change Management Plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "planId": { "type": "string" },
        "version": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "data": { "type": "object" },
        "changeSummary": { "type": "string" }
      },
      "required": ["planId", "version", "timestamp", "userId", "data"]
    },
    "ProjectManagementPlan": {
      "title": "Project Management Plan",
      "description": "Master project management plan including life cycle, tailoring, and baselines.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "phases": { "type": "array", "items": { "type": "object" } },
        "tailoringDecisions": { "type": "array", "items": { "type": "object" } },
        "baselines": { "type": "object" },
        "version": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["projectId", "phases", "tailoringDecisions", "baselines", "version"]
    },
    "ProjectManagementVersion": {
      "title": "Project Management Version",
      "description": "Historical versions of the Project Management Plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "planId": { "type": "string" },
        "version": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "data": { "type": "object" },
        "changeSummary": { "type": "string" }
      },
      "required": ["planId", "version", "timestamp", "userId", "data"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Project personnel information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "workHours": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Off-site"] }
      },
      "required": ["name", "role", "email"]
    },
    "TeamOperatingAgreement": {
      "title": "Team Operating Agreement",
      "description": "Guidelines for team interaction and governance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "values": { "type": "string" },
        "meetingGuidelines": { "type": "string" },
        "communicationGuidelines": { "type": "string" },
        "decisionMaking": { "type": "string" },
        "conflictManagement": { "type": "string" },
        "raci": { "type": "object" }
      },
      "required": ["projectId"]
    },
    "PerformanceAssessment": {
      "title": "Performance Assessment",
      "description": "Individual team member performance evaluation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "memberRole": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "technicalRating": { "type": "string", "enum": ["Exceeds", "Meets", "Needs Improvement"] },
        "interpersonalRating": { "type": "string", "enum": ["Exceeds", "Meets", "Needs Improvement"] },
        "strengths": { "type": "string" },
        "weaknesses": { "type": "string" },
        "developmentAreas": { "type": "string" },
        "moraleScore": { "type": "number" },
        "overallRating": { "type": "string" }
      },
      "required": ["memberId", "date", "technicalRating", "interpersonalRating"]
    },
    "TeamStatusReport": {
      "title": "Team Status Report",
      "description": "Periodic team progress and financial report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "plannedActivities": { "type": "array", "items": { "type": "string" } },
        "accomplishedActivities": { "type": "array", "items": { "type": "string" } },
        "variances": { "type": "string" },
        "rootCause": { "type": "string" },
        "correctiveActions": { "type": "string" },
        "fundsPlanned": { "type": "number" },
        "fundsSpent": { "type": "number" },
        "variancePercent": { "type": "number" }
      },
      "required": ["projectId", "date"]
    },
    "ResourceRequirement": {
      "title": "Resource Requirement",
      "description": "Resource needs per activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "wbsId": { "type": "string" },
        "activityId": { "type": "string" },
        "resourceType": { "type": "string", "enum": ["Labor", "Material", "Equipment"] },
        "resourceName": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "rate": { "type": "number" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Approved"] }
      },
      "required": ["projectId", "resourceName", "resourceType", "quantity", "rate"]
    },
    "RBSNode": {
      "title": "RBS Node",
      "description": "Hierarchical resource structure node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "parentId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Category", "Resource"] },
        "resourceType": { "type": "string", "enum": ["Labor", "Material", "Equipment"] },
        "description": { "type": "string" }
      },
      "required": ["projectId", "title", "type"]
    },
    "RoleResponsibility": {
      "title": "Role & Responsibility",
      "description": "Position description and authority.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "position": { "type": "string" },
        "authority": { "type": "string" },
        "responsibility": { "type": "string" },
        "qualifications": { "type": "string" }
      },
      "required": ["projectId", "position", "authority", "responsibility"]
    },
    "SelectionCriterion": {
      "title": "Selection Criterion",
      "description": "Weighted criterion for vendor evaluation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "criterion": { "type": "string" },
        "weight": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["projectId", "criterion", "weight"]
    },
    "VendorEvaluation": {
      "title": "Vendor Evaluation",
      "description": "Scoring of a vendor against criteria.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "criteriaScores": { "type": "array", "items": { "type": "object" } },
        "totalScore": { "type": "number" },
        "comments": { "type": "string" }
      },
      "required": ["projectId", "vendorId", "totalScore"]
    },
    "ProcessImprovement": {
      "title": "Process Improvement",
      "description": "Workflow optimization record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "workflowName": { "type": "string" },
        "currentProcess": { "type": "string" },
        "improvedProcess": { "type": "string" },
        "justification": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Implemented"] }
      },
      "required": ["projectId", "workflowName", "currentProcess", "improvedProcess"]
    },
    "WBSLevel": {
      "title": "WBS Level",
      "description": "A node in the Work Breakdown Structure.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "parentId": { "type": "string" },
        "divisionCode": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Zone", "Area", "Building", "Floor", "Cost Account", "Work Package"] },
        "level": { "type": "number" },
        "status": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["projectId", "title", "type"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A single construction activity or task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "wbsId": { "type": "string" },
        "workPackage": { "type": "string" },
        "description": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "rate": { "type": "number" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Planned", "In Progress", "Completed", "Converted to PO"] }
      },
      "required": ["projectId", "wbsId", "workPackage", "description", "status"]
    },
    "Company": {
      "title": "Company",
      "description": "An organization or corporate entity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Main", "Supplier", "Stakeholder", "Other"] },
        "parent_entity_id": { "type": "string" },
        "entity_type": { "type": "string", "enum": ["holding", "division", "department", "subsidiary", "vendor"] },
        "is_internal": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["name", "type", "is_internal", "status"]
    },
    "ProjectContract": {
      "title": "Project Contract",
      "description": "An official contract or agreement with a vendor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contractId": { "type": "string" },
        "projectId": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "contractValue": { "type": "number" },
        "awardDate": { "type": "string", "format": "date" },
        "tenderNumber": { "type": "string" },
        "contractType": { "type": "string", "enum": ["Agreement", "Official Contract"] },
        "costCenterId": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Active", "Ended", "Suspended"] }
      },
      "required": ["contractId", "projectId", "vendorId", "contractValue", "contractType", "status"]
    }
  },
  "firestore": {
    "/companies/{id}": {
      "schema": "Company",
      "description": "Enterprise structure and company directory."
    },
    "/wbs/{id}": {
      "schema": "WBSLevel",
      "description": "Work Breakdown Structure levels."
    },
    "/activities/{id}": {
      "schema": "Activity",
      "description": "Project activities."
    },
    "/resource_requirements/{id}": {
      "schema": "ResourceRequirement",
      "description": "Resource requirements per activity."
    },
    "/rbs/{id}": {
      "schema": "RBSNode",
      "description": "Resource Breakdown Structure."
    },
    "/roles_responsibilities/{id}": {
      "schema": "RoleResponsibility",
      "description": "Roles and responsibilities definitions."
    },
    "/selection_criteria/{id}": {
      "schema": "SelectionCriterion",
      "description": "Vendor selection criteria."
    },
    "/vendor_evaluations/{id}": {
      "schema": "VendorEvaluation",
      "description": "Vendor evaluation scores."
    },
    "/process_improvements/{id}": {
      "schema": "ProcessImprovement",
      "description": "Process improvement logs."
    },
    "/ram_raci/{projectId}": {
      "schema": "object",
      "description": "RAM / RACI Matrix data."
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles indexed by UID."
    },
    "/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Project team members."
    },
    "/team_governance/{agreementId}": {
      "schema": "TeamOperatingAgreement",
      "description": "Team operating agreements and RACI."
    },
    "/performance_assessments/{assessmentId}": {
      "schema": "PerformanceAssessment",
      "description": "Individual performance evaluations."
    },
    "/team_status_reports/{reportId}": {
      "schema": "TeamStatusReport",
      "description": "Team status and financial reports."
    },
    "/boq/{itemId}": {
      "schema": "BOQItem",
      "description": "Bill of Quantities items."
    },
    "/purchaseOrders/{poId}": {
      "schema": "PurchaseOrder",
      "description": "Purchase orders."
    },
    "/progressReports/{reportId}": {
      "schema": "DailyReport",
      "description": "Progress reports (daily, weekly, monthly)."
    },
    "/siteIssues/{issueId}": {
      "schema": "SiteIssue",
      "description": "Technical issues and assignments."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project metadata and settings."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Project tasks."
    },
    "/workspaces/{workspaceId}": {
      "schema": "Workspace",
      "description": "Collaborative workspaces."
    },
    "/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Meeting records and minutes."
    },
    "/changeManagementPlans/{planId}": {
      "schema": "ChangeManagementPlan",
      "description": "Change management plans."
    },
    "/changeManagementVersions/{versionId}": {
      "schema": "ChangeManagementVersion",
      "description": "Change management plan versions."
    },
    "/projectManagementPlans/{planId}": {
      "schema": "ProjectManagementPlan",
      "description": "Master project management plans."
    },
    "/projectManagementVersions/{versionId}": {
      "schema": "ProjectManagementVersion",
      "description": "Project management plan versions."
    },
    "/contracts/{id}": {
      "schema": "ProjectContract",
      "description": "Official project contracts and agreements."
    }
  }
}
